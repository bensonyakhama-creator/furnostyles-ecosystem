# Furnostyles Environment Configuration Example
# Copy this file to .env and fill in actual values for production deployment

# Firebase Configuration
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Payment Gateway Configuration (DO NOT commit real keys)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
PAYSTACK_PUBLIC_KEY=your_paystack_public_key
PAYSTACK_SECRET_KEY=your_paystack_secret_key
STRIPE_PUBLIC_KEY=your_stripe_public_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# Application Configuration
APP_ENV=production
APP_URL=https://furnostyles.com
WHATSAPP_NUMBER=254713639205
SUPPORT_EMAIL=furnostyles@gmail.com

# Analytics Configuration
GOOGLE_ANALYTICS_ID=your_ga_id_here
